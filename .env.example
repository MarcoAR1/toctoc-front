# === TocToc Front — variables de entorno ===
# Copiá este archivo a .env y ajustá los valores. NUNCA commitees .env (está gitignored).

# Base URL del backend TocToc (Express + TSOA). En dev suele ser localhost:8080.
VITE_API_URL=http://localhost:8080

# URL pública de ESTA app. Se usa para componer los QR (panel admin) y los deep links
# de magic link (/auth/verify) e invitaciones (/invite/accept). En dev: localhost:5173.
VITE_APP_URL=http://localhost:5173

# Servidores ICE para WebRTC (llamada en vivo), separados por coma.
# STUN: "stun:host:puerto". TURN: "turn:host:puerto|usuario|credencial".
# Sin TURN muchas llamadas P2P fallan tras NAT estricto en producción.
VITE_ICE_SERVERS=stun:stun.l.google.com:19302

# === Google OAuth (opcional, drop-in) ===
# El botón "Continuar con Google" aparece SOLO si VITE_GOOGLE_CLIENT_ID está definido.
# Dejalo vacío/sin definir para ocultarlo por completo (login = sólo magic link).
# Client ID OAuth 2.0 de la consola de Google Cloud (tipo "Web application").
VITE_GOOGLE_CLIENT_ID=
# Ruta del backend que verifica el ID token de Google y devuelve { accessToken, user }.
# Opcional; default /auth/google. El backend de este endpoint todavía está pendiente.
VITE_GOOGLE_AUTH_PATH=/auth/google
